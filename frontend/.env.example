# Copie para .env e ajuste conforme o backend.
# Enquanto VITE_USE_MOCK=true, o app usa a camada mock em memória (src/api/mock.ts)
# e NÃO faz chamadas de rede. Troque para false quando o Express estiver no ar.
VITE_USE_MOCK=true
# Sem sufixo /api — as rotas do backend (../backend) são montadas na raiz (/auth, /tasks, ...).
# Socket.IO usa o mesmo host (resolvido com fallback em api/client.ts — ver CANDIDATE_BASE_URLS).
VITE_API_BASE_URL=http://localhost:3001
