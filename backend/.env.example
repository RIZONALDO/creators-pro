# Copie para .env (dev) e .env.test (banco de teste) — nenhum dos dois deve ir pro git.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/creatorspro_dev
JWT_SECRET=troque-este-segredo-em-produção
JWT_REFRESH_SECRET=troque-este-segredo-tambem
PLATFORM_PROVISION_SECRET=segredo-interno-para-provisionar-novos-tenants
PORT=3001
# Push notification (Web Push) — opcional: sem isto, o app funciona normal, só não envia push.
# Gerar par novo: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@creatorspro.app
# Anexos: storage é sempre disco local (sem S3/terceiros) — pasta relativa à raiz do backend.
UPLOADS_DIR=uploads
# Rate limit de /auth/login (brute-force) — opcional, default 10 tentativas / 15min se omitido.
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
# Self-service signup + billing (Stripe) — opcional: sem isto, /signup e /billing/portal recusam
# com BILLING_NOT_CONFIGURED, o resto do app roda normal.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
APP_URL=http://localhost:5173
