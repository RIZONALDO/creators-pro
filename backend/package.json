{
  "name": "creatorspro-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CreatorsPro — backend (Express + Drizzle + PostgreSQL + Socket.IO, multi-tenant). Ver /specs na raiz do monorepo.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "NODE_OPTIONS=--import=tsx drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:test": "DOTENV_CONFIG_PATH=.env.test tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "otpauth": "^9.5.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "resend": "^6.14.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.2",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.24.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
